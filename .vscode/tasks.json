{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "claude-code: setup mcp servers",
      "type": "shell",
      "command": "sh",
      "args": [".vscode${/}scripts${/}setup-claude-mcp-servers.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "claude-code: setup plugins",
      "type": "shell",
      "command": "sh",
      "args": [".vscode${/}scripts${/}setup-claude-plugins.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "vitest: run tests",
      "type": "shell",
      "command": "pnpm",
      "args": ["vitest", "run"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "vitest: run tests in watch mode",
      "type": "shell",
      "command": "pnpm",
      "args": ["vitest", "watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "vitest: run tests in watch mode with coverage",
      "type": "shell",
      "command": "pnpm",
      "args": ["vitest", "watch", "--coverage"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    }
  ]
}
