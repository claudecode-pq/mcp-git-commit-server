{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "claude-code: setup mcp servers",
      "type": "shell",
      "command": "sh",
      "args": [".vscode${/}scripts${/}setup-claude-mcp-servers.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "claude-code: setup plugins",
      "type": "shell",
      "command": "sh",
      "args": [".vscode${/}scripts${/}setup-claude-plugins.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "run format",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "format"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run inspector",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "inspector"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": [],
      "dependsOn": ["build"]
    },
    {
      "label": "run lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run lint with fix",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "lint:fix"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run tests",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run tests in watch mode",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test:watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "run tests in watch mode with coverage",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test:coverage"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    }
  ]
}
