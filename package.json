{
  "name": "@claudecode-pq/mcp-git-commit-server",
  "version": "1.0.1",
  "description": "MCP server that analyzes staged git changes and executes conventional commits via Claude",
  "type": "module",
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "bin": {
    "mcp-git-commit-server": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pnpm install --frozen-lockfile false && pnpm version ${nextRelease.version} --no-git-tag-version"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "pnpm-lock.yaml"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "conventional-commits",
    "claude"
  ],
  "author": "Patrick Joseph Quijano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudecode-pq/mcp-git-commit-server.git"
  },
  "scripts": {
    "build": "tsc --rootDir src --outDir build && chmod 755 build/index.js",
    "format": "prettier --write .",
    "inspector": "pnpx @modelcontextprotocol/inspector build/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "pnpm run lint:fix && pnpm run format && pnpm run test && pnpm run build",
    "prepublishOnly": "pnpm run test && pnpm run build",
    "start": "tsx index.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
